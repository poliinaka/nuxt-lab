generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Tariff {
  id          Int      @id @default(autoincrement())
  title       String
  price       Int
  description String
  createdAt   DateTime @default(now())
}